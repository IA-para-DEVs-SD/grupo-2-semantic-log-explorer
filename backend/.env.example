# Google Gemini API key (obrigatório)
GOOGLE_API_KEY=sua_chave_aqui

# Nome da coleção no ChromaDB (padrão: log_chunks)
CHROMA_COLLECTION_NAME=log_chunks

# Tamanho máximo de arquivo em MB (padrão: 50)
MAX_FILE_SIZE_MB=50

# Extensões permitidas para upload (padrão: .log,.txt,.json)
ALLOWED_EXTENSIONS=.log,.txt,.json
